    {
      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar recipeId = String(m.recipe_id || '').trim();\n\nvar validActions = ['add', 'remove', 'list'];\n\nif (!token) {\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Authentication required. Please provide a valid token.' }\n  };\n  result;\n} else if (validActions.indexOf(action) === -1) {\n  var result = {\n    route: 'error',\n    statusCode: 400,\n    response: { success: false, error: 'Invalid action. Must be one of: add, remove, list.' }\n  };\n  result;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var userId = String(decoded.sub || '');\n    var userName = String(decoded.name || '');\n\n    if (!userId) {\n      var result = {\n        route: 'error',\n        statusCode: 401,\n        response: { success: false, error: 'Invalid token.' }\n      };\n      result;\n    } else if ((action === 'add' || action === 'remove') && !recipeId) {\n      var result = {\n        route: 'error',\n        statusCode: 400,\n        response: { success: false, error: 'recipe_id is required for add/remove actions.' }\n      };\n      result;\n    } else {\n      var result = {\n        route: action,\n        user_id: userId,\n        user_name: userName,\n        recipe_id: recipeId,\n        created_at: new Date().toISOString()\n      };\n      result;\n    }\n  } catch (e) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid or expired token.' }\n    };\n    result;\n  }\n}",
            "language": "javascript",
            "name": "Verify JWT & Validate Action",
            "saved": 0,
            "variable": "auth"
          }
        },
        "description": {
          "text": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar recipeId = String(m.recipe_id || '').trim();\n\nvar validActions = ['add', 'remove', 'list'];\n\nif (!token) {\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Authentication required. Please provide a valid token.' }\n  };\n  result;\n} else if (validActions.indexOf(action) === -1) {\n  var result = {\n    route: 'error',\n    statusCode: 400,\n    response: { success: false, error: 'Invalid action. Must be one of: add, remove, list.' }\n  };\n  result;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var userId = String(decoded.sub || '');\n    var userName = String(decoded.name || '');\n\n    if (!userId) {\n      var result = {\n        route: 'error',\n        statusCode: 401,\n        response: { success: false, error: 'Invalid token.' }\n      };\n      result;\n    } else if ((action === 'add' || action === 'remove') && !recipeId) {\n      var result = {\n        route: 'error',\n        statusCode: 400,\n        response: { success: false, error: 'recipe_id is required for add/remove actions.' }\n      };\n      result;\n    } else {\n      var result = {\n        route: action,\n        user_id: userId,\n        user_name: userName,\n        recipe_id: recipeId,\n        created_at: new Date().toISOString()\n      };\n      result;\n    }\n  } catch (e) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid or expired token.' }\n    };\n    result;\n  }\n}"
