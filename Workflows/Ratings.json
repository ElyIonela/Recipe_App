          "extra": {
            "code": "var data = variables.allRatings || {};\nvar rows = data.rows || [];\n\nvar count = rows.length;\nvar sum = 0;\nfor (var i = 0; i < rows.length; i++) {\n  sum += Number(rows[i].rating) || 0;\n}\n\nvar avg = count > 0 ? Math.round((sum / count) * 10) / 10 : 0;\n\nvar result = {\n  avg_rating: avg,\n  rating_count: count\n};\nresult;",
