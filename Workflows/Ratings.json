    {
      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar recipeId = String(m.recipe_id || '').trim();\nvar ratingVal = Number(m.rating);\n\nvar validActions = ['rate', 'get_my_rating'];\n\nif (!token) {\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Authentication required. Please provide a valid token.' }\n  };\n  result;\n} else if (validActions.indexOf(action) === -1) {\n  var result = {\n    route: 'error',\n    statusCode: 400,\n    response: { success: false, error: 'Invalid action. Must be one of: rate, get_my_rating.' }\n  };\n  result;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var userId = String(decoded.sub || '');\n\n    if (!userId) {\n      var result = {\n        route: 'error',\n        statusCode: 401,\n        response: { success: false, error: 'Invalid token.' }\n      };\n      result;\n    } else if (!recipeId) {\n      var result = {\n        route: 'error',\n        statusCode: 400,\n        response: { success: false, error: 'recipe_id is required.' }\n      };\n      result;\n    } else if (action === 'rate') {\n      if (isNaN(ratingVal) || ratingVal < 1 || ratingVal > 5 || Math.floor(ratingVal) !== ratingVal) {\n        var result = {\n          route: 'error',\n          statusCode: 400,\n          response: { success: false, error: 'rating must be an integer between 1 and 5.' }\n        };\n        result;\n      } else {\n        var result = {\n          route: 'rate',\n          user_id: userId,\n          recipe_id: recipeId,\n          rating: ratingVal,\n          created_at: new Date().toISOString()\n        };\n        result;\n      }\n    } else {\n      var result = {\n        route: 'get_my_rating',\n        user_id: userId,\n        recipe_id: recipeId\n      };\n      result;\n    }\n  } catch (e) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid or expired token.' }\n    };\n    result;\n  }\n}",
            "language": "javascript",
            "name": "Verify JWT & Validate Action",
            "saved": 0,
            "variable": "auth"
          }
        },
        "description": {
          "text": "Verify JWT, validate action, rating value"
        },
        "icon": {
          "xlinkHref": "./assets/images/dia/code.svg"
