    {
      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar recipeId = String(m.recipe_id || '').trim();\nvar commentId = String(m.comment_id || '').trim();\nvar text = String(m.text || '').trim();\nvar imageUrl = String(m.image_url || '').trim();\n\nvar validActions = ['add', 'list', 'delete'];\n\n// list does not require auth — anyone can read comments\nif (action === 'list') {\n  if (!recipeId) {\n    var result = {\n      route: 'error',\n      statusCode: 400,\n      response: { success: false, error: 'recipe_id is required for list action.' }\n    };\n    result;\n  } else {\n    var result = {\n      route: 'list',\n      recipe_id: recipeId\n    };\n    result;\n  }\n} else if (!token) {\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Authentication required. Please provide a valid token.' }\n  };\n  result;\n} else if (validActions.indexOf(action) === -1) {\n  var result = {\n    route: 'error',\n    statusCode: 400,\n    response: { success: false, error: 'Invalid action. Must be one of: add, list, delete.' }\n  };\n  result;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var userId = String(decoded.sub || '');\n    var userName = String(decoded.name || '');\n    var userRole = String(decoded.role || 'user');\n\n    if (!userId) {\n      var result = {\n        route: 'error',\n        statusCode: 401,\n        response: { success: false, error: 'Invalid token.' }\n      };\n      result;\n    } else if (action === 'add') {\n      if (!recipeId) {\n        var result = {\n          route: 'error',\n          statusCode: 400,\n          response: { success: false, error: 'recipe_id is required.' }\n        };\n        result;\n      } else if (!text) {\n        var result = {\n          route: 'error',\n          statusCode: 400,\n          response: { success: false, error: 'text is required for adding a comment.' }\n        };\n        result;\n      } else {\n        var result = {\n          route: 'add',\n          user_id: userId,\n          user_name: userName,\n          user_role: userRole,\n          recipe_id: recipeId,\n          text: text,\n          image_url: imageUrl,\n          created_at: new Date().toISOString()\n        };\n        result;\n      }\n    } else if (action === 'delete') {\n      if (!commentId) {\n        var result = {\n          route: 'error',\n          statusCode: 400,\n          response: { success: false, error: 'comment_id is required for delete action.' }\n        };\n        result;\n      } else {\n        var result = {\n          route: 'delete',\n          user_id: userId,\n          user_role: userRole,\n          comment_id: commentId\n        };\n        result;\n      }\n    } else {\n      var result = {\n        route: 'error',\n        statusCode: 400,\n        response: { success: false, error: 'Invalid action.' }\n      };\n      result;\n    }\n  } catch (e) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid or expired token.' }\n    };\n    result;\n  }\n}",
            "language": "javascript",
            "name": "Verify JWT & Validate Action",
            "saved": 0,
            "variable": "auth"
          }
        },
        "description": {
          "text": "Verify JWT, validate action and required fields"
        },
        "icon": {
          "xlinkHref": "./assets/images/dia/code.svg"
        },
        "variable": {
