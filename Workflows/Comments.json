      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var data = variables.foundComment || {};\nvar rows = data.rows || [];\nvar a = variables.auth || {};\nvar userId = String(a.user_id || '');\nvar userRole = String(a.user_role || 'user');\n\nif (rows.length === 0) {\n  var result = {\n    allowed: 'no',\n    statusCode: 404,\n    response: { success: false, error: 'Comment not found.' }\n  };\n  result;\n} else {\n  var comment = rows[0];\n  var commentOwnerId = String(comment.user_id || '');\n\n  // Allow delete if user owns the comment or is admin\n  if (commentOwnerId === userId || userRole === 'admin') {\n    var result = { allowed: 'yes' };\n    result;\n  } else {\n    var result = {\n      allowed: 'no',\n      statusCode: 403,\n      response: { success: false, error: 'You can only delete your own comments.' }\n    };\n    result;\n  }\n}",
