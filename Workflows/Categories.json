    {
      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar catId = String(m.category_id || '').trim();\n\nif (!action) action = 'list';\nvar validActions = ['list', 'add', 'edit', 'delete'];\n\nif (validActions.indexOf(action) === -1) {\n  var r = { route:'error', statusCode:400, response:{ success:false, error:'Invalid action. Must be: list, add, edit, delete.' } }; r;\n} else if (action === 'list') {\n  var r = { route:'list' }; r;\n} else {\n  if (!token) {\n    var r = { route:'error', statusCode:401, response:{ success:false, error:'Authentication required.' } }; r;\n  } else {\n    try {\n      var secret = variables.secrets.my_jwt_secret;\n      var decoded = jwtVerify(token, secret);\n      var userRole = String(decoded.role || 'user');\n      if (userRole !== 'admin') {\n        var r = { route:'error', statusCode:403, response:{ success:false, error:'Admin access required.' } }; r;\n      } else if (action === 'add') {\n        var name = String(m.name || '').trim();\n        if (!name) {\n          var r = { route:'error', statusCode:400, response:{ success:false, error:'name is required.' } }; r;\n        } else {\n          var r = { route:'add', name:name, icon:String(m.icon||'').trim(), sort_order:Number(m.sort_order)||0 }; r;\n        }\n      } else if (action === 'edit') {\n        if (!catId) {\n          var r = { route:'error', statusCode:400, response:{ success:false, error:'category_id is required.' } }; r;\n        } else {\n          var r = { route:'edit', category_id:catId, name:String(m.name||'').trim(), icon:String(m.icon||'').trim(), sort_order:Number(m.sort_order)||0 }; r;\n        }\n      } else if (action === 'delete') {\n        if (!catId) {\n          var r = { route:'error', statusCode:400, response:{ success:false, error:'category_id is required.' } }; r;\n        } else {\n          var r = { route:'delete', category_id:catId }; r;\n        }\n      } else {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'Unknown action.' } }; r;\n      }\n    } catch(e) {\n      var r = { route:'error', statusCode:401, response:{ success:false, error:'Invalid or expired token.' } }; r;\n    }\n  }\n}",
            "language": "javascript",
            "name": "Auth & Route",
            "saved": 0,
            "variable": "auth"
          }
        },
        "description": {
          "text": "Validate action, admin auth"
        },
        "icon": {
          "xlinkHref": "./assets/images/dia/code.svg"
        },
