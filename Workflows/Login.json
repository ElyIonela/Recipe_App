    {
      "id": "code-router",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "pulsing-opacity",
          "opacity": "1",
          "stroke": "#ffffff"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar email = String(m.email || '').toLowerCase().trim();\nvar password = String(m.password || '');\n\nvar userData = variables.found_user || {};\nvar rows = userData.rows || [];\n\nif (rows.length === 0) {\n  // Generic error to prevent user enumeration\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Invalid email or password.' }\n  };\n  result;\n} else {\n  var user = rows[0];\n  var storedHash = String(user.password_hash || '');\n\n  // Verify password against bcrypt hash\n  var passwordValid = bcryptVerify(password, storedHash);\n\n  if (!passwordValid) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid email or password.' }\n    };\n    result;\n  } else {\n    var secret = variables.secrets.my_jwt_secret;\n    if (!secret) {\n      var result = {\n        route: 'error',\n        statusCode: 500,\n        response: { success: false, error: 'Server configuration error.' }\n      };\n      result;\n    } else {\n      var now = Date.now();\n      var iat = Math.floor(now / 1000);\n      var exp = iat + 31536000; // 365 days\n\n      var userId = String(user._id || '');\n      var userName = String(user.name || '');\n      var userRole = String(user.role || 'user');\n\n      var token = jwtSign({\n        sub: userId,\n        email: email,\n        name: userName,\n        role: userRole,\n        iss: 'recipe-app',\n        iat: iat,\n        exp: exp\n      }, secret);\n\n      var result = {\n        route: 'success',\n        response: {\n          success: true,\n          token: token,\n          user: {\n            id: userId,\n            name: userName,\n            email: email,\n            role: userRole\n          }\n        }\n      };\n      result;\n    }\n  }\n}",
            "language": "javascript",
            "name": "Verify Password & Generate JWT",
            "saved": 0,
            "variable": "router"
          }
        },
        "description": {
          "text": "var m = variables.mapper || {};\nvar email = String(m.email || '').toLowerCase().trim();\nvar password = String(m.password || '');\n\nvar userData = variables.found_user || {};\nvar rows = userData.rows || [];\n\nif (rows.length === 0) {\n  // Generic error to prevent user enumeration\n  var result = {\n    route: 'error',\n    statusCode: 401,\n    response: { success: false, error: 'Invalid email or password.' }\n  };\n  result;\n} else {\n  var user = rows[0];\n  var storedHash = String(user.password_hash || '');\n\n  // Verify password against bcrypt hash\n  var passwordValid = bcryptVerify(password, storedHash);\n\n  if (!passwordValid) {\n    var result = {\n      route: 'error',\n      statusCode: 401,\n      response: { success: false, error: 'Invalid email or password.' }\n    };\n    result;\n  } else {\n    var secret = variables.secrets.my_jwt_secret;\n    if (!secret) {\n      var result = {\n        route: 'error',\n        statusCode: 500,\n        response: { success: false, error: 'Server configuration error.' }\n      };\n      result;\n    } else {\n      var now = Date.now();\n      var iat = Math.floor(now / 1000);\n      var exp = iat + 31536000; // 365 days\n\n      var userId = String(user._id || '');\n      var userName = String(user.name || '');\n      var userRole = String(user.role || 'user');\n\n      var token = jwtSign({\n        sub: userId,\n        email: email,\n        name: userName,\n        role: userRole,\n        iss: 'recipe-app',\n        iat: iat,\n        exp: exp\n      }, secret);\n\n      var result = {\n        route: 'success',\n        response: {\n          success: true,\n          token: token,\n          user: {\n            id: userId,\n            name: userName,\n            email: email,\n            role: userRole\n          }\n        }\n      };\n      result;\n    }\n  }\n}"
        },
