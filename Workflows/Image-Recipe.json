      "id": "code-parse",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var action = String(variables.action || '').toLowerCase().trim();\nvar token = String(variables.token || '').trim();\nvar recipeId = String(variables.recipe_id || '').trim();\nvar imagePath = String(variables.image_path || '').trim();\nvar files = variables.files || [];\n\nif (action === 'get') {\n  // Get image — public, just needs image_path\n  if (!imagePath) {\n    var r = { route:'error', statusCode:400, response:{ success:false, error:'image_path is required.' } }; r;\n  } else {\n    var r = { route:'get', image_path:imagePath }; r;\n  }\n} else if (action === 'upload') {\n  // Upload — requires auth + file + recipe_id\n  if (!token) {\n    var r = { route:'error', statusCode:401, response:{ success:false, error:'Authentication required.' } }; r;\n  } else if (!recipeId) {\n    var r = { route:'error', statusCode:400, response:{ success:false, error:'recipe_id is required.' } }; r;\n  } else if (files.length === 0) {\n    var r = { route:'error', statusCode:400, response:{ success:false, error:'No file uploaded.' } }; r;\n  } else {\n    try {\n      var secret = variables.secrets.my_jwt_secret;\n      var decoded = jwtVerify(token, secret);\n      var userId = String(decoded.sub || '');\n      if (!userId) {\n        var r = { route:'error', statusCode:401, response:{ success:false, error:'Invalid token.' } }; r;\n      } else {\n        var filePath = String(files[0]);\n        var ext = filePath.split('.').pop().toLowerCase();\n        var allowed = ['png','jpg','jpeg','gif','webp'];\n        if (allowed.indexOf(ext) === -1) {\n          var r = { route:'error', statusCode:400, response:{ success:false, error:'Only image files allowed (png, jpg, jpeg, gif, webp).' } }; r;\n        } else {\n          var ts = Date.now();\n          var newPath = '/recipe-images/' + recipeId + '/' + ts + '.' + ext;\n          var r = {\n            route:'upload',\n            user_id: userId,\n            recipe_id: recipeId,\n            file_path: filePath,\n            new_path: newPath,\n            new_path_versioned: newPath + '?v=' + ts\n          }; r;\n        }\n      }\n    } catch(e) {\n      var r = { route:'error', statusCode:401, response:{ success:false, error:'Invalid or expired token.' } }; r;\n    }\n  }\n} else {\n  var r = { route:'error', statusCode:400, response:{ success:false, error:'Invalid action. Must be: upload, get.' } }; r;\n}",
            "language": "javascript",
            "name": "Parse & Validate",
            "saved": 0,
            "variable": "parsed"
          }
        },
