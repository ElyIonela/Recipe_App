      "id": "code-fmt-image",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var fileContent = variables.fileData;\nvar base64 = '';\nif (typeof fileContent === 'string') {\n  base64 = fileContent;\n} else if (fileContent && typeof fileContent === 'object') {\n  base64 = fileContent.content || fileContent.data || fileContent.base64 || fileContent.body || '';\n}\nif (base64.indexOf('data:') === 0) {\n  var ci = base64.indexOf(',');\n  if (ci !== -1) base64 = base64.substring(ci + 1);\n}\nbase64 = String(base64).replace(/\\s/g, '');\n\nvar path = String(variables.parsed.image_path || '').toLowerCase();\nvar mime = 'image/jpeg';\nif (path.indexOf('.png') !== -1) mime = 'image/png';\nelse if (path.indexOf('.gif') !== -1) mime = 'image/gif';\nelse if (path.indexOf('.webp') !== -1) mime = 'image/webp';\n\nvar result = { base64: 'data:' + mime + ';base64,' + base64, mimeType: mime };\nresult;",
            "language": "javascript",
            "name": "Format Image",
            "saved": 0,
            "variable": "imageResponse"
          }
        },
