      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar targetUserId = String(m.user_id || '').trim();\nvar newRole = String(m.new_role || '').trim();\n\nvar validActions = ['list', 'change_role', 'delete'];\n\nif (validActions.indexOf(action) === -1) {\n  var r = { route:'error', statusCode:400, response:{ success:false, error:'Invalid action. Must be: list, change_role, delete.' } }; r;\n} else if (!token) {\n  var r = { route:'error', statusCode:401, response:{ success:false, error:'Authentication required.' } }; r;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var callerRole = String(decoded.role || 'user');\n    var callerId = String(decoded.sub || '');\n    if (callerRole !== 'admin') {\n      var r = { route:'error', statusCode:403, response:{ success:false, error:'Admin access required.' } }; r;\n    } else if (action === 'list') {\n      var r = { route:'list' }; r;\n    } else if (action === 'change_role') {\n      if (!targetUserId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'user_id is required.' } }; r;\n      } else if (newRole !== 'user' && newRole !== 'admin') {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'new_role must be user or admin.' } }; r;\n      } else if (targetUserId === callerId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'Cannot change your own role.' } }; r;\n      } else {\n        var r = { route:'change_role', user_id:targetUserId, new_role:newRole }; r;\n      }\n    } else if (action === 'delete') {\n      if (!targetUserId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'user_id is required.' } }; r;\n      } else if (targetUserId === callerId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'Cannot delete yourself.' } }; r;\n      } else {\n        var r = { route:'delete', user_id:targetUserId }; r;\n      }\n    }\n  } catch(e) {\n    var r = { route:'error', statusCode:401, response:{ success:false, error:'Invalid or expired token.' } }; r;\n  }\n}",
            "language": "javascript",
            "name": "Auth & Route",
            "saved": 0,
            "variable": "auth"
          }
        },
        "description": {
          "text": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar action = String(m.action || '').toLowerCase().trim();\nvar targetUserId = String(m.user_id || '').trim();\nvar newRole = String(m.new_role || '').trim();\n\nvar validActions = ['list', 'change_role', 'delete'];\n\nif (validActions.indexOf(action) === -1) {\n  var r = { route:'error', statusCode:400, response:{ success:false, error:'Invalid action. Must be: list, change_role, delete.' } }; r;\n} else if (!token) {\n  var r = { route:'error', statusCode:401, response:{ success:false, error:'Authentication required.' } }; r;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var callerRole = String(decoded.role || 'user');\n    var callerId = String(decoded.sub || '');\n    if (callerRole !== 'admin') {\n      var r = { route:'error', statusCode:403, response:{ success:false, error:'Admin access required.' } }; r;\n    } else if (action === 'list') {\n      var r = { route:'list' }; r;\n    } else if (action === 'change_role') {\n      if (!targetUserId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'user_id is required.' } }; r;\n      } else if (newRole !== 'user' && newRole !== 'admin') {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'new_role must be user or admin.' } }; r;\n      } else if (targetUserId === callerId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'Cannot change your own role.' } }; r;\n      } else {\n        var r = { route:'change_role', user_id:targetUserId, new_role:newRole }; r;\n      }\n    } else if (action === 'delete') {\n      if (!targetUserId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'user_id is required.' } }; r;\n      } else if (targetUserId === callerId) {\n        var r = { route:'error', statusCode:400, response:{ success:false, error:'Cannot delete yourself.' } }; r;\n      } else {\n        var r = { route:'delete', user_id:targetUserId }; r;\n      }\n    }\n  } catch(e) {\n    var r = { route:'error', statusCode:401, response:{ success:false, error:'Invalid or expired token.' } }; r;\n  }\n}"
