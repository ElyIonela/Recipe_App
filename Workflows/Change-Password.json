        },
        "codeJs": {
          "extra": {
            "code": "var data = variables.userData || {};\nvar rows = data.rows || [];\nvar a = variables.auth || {};\n\nif (rows.length === 0) {\n  var r = { ok:'no', statusCode:404, response:{ success:false, error:'User not found.' } }; r;\n} else {\n  var user = rows[0];\n  var storedHash = String(user.password_hash || '');\n  var currentPw = String(a.current_password || '');\n  var newPw = String(a.new_password || '');\n\n  if (!bcryptVerify(currentPw, storedHash)) {\n    var r = { ok:'no', statusCode:400, response:{ success:false, error:'Current password is incorrect.' } }; r;\n  } else if (bcryptVerify(newPw, storedHash)) {\n    var r = { ok:'no', statusCode:400, response:{ success:false, error:'New password must be different from current password.' } }; r;\n  } else {\n    var hashedNew = bcryptHash(newPw, 10);\n    var r = { ok:'yes', new_hash:hashedNew, user_id:a.user_id }; r;\n  }\n}",
            "language": "javascript",
            "name": "Verify Current & Hash New",
            "saved": 0,
