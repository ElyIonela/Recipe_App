    {
      "id": "code-auth",
      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar token = String(m.token || '').trim();\nvar currentPw = String(m.current_password || '');\nvar newPw = String(m.new_password || '');\n\nif (!token) {\n  var r = { valid:'no', statusCode:401, response:{ success:false, error:'Authentication required.' } }; r;\n} else if (!currentPw) {\n  var r = { valid:'no', statusCode:400, response:{ success:false, error:'Current password is required.' } }; r;\n} else if (newPw.length < 6) {\n  var r = { valid:'no', statusCode:400, response:{ success:false, error:'New password must be at least 6 characters.' } }; r;\n} else {\n  try {\n    var secret = variables.secrets.my_jwt_secret;\n    var decoded = jwtVerify(token, secret);\n    var userId = String(decoded.sub || '');\n    var email = String(decoded.email || '');\n    if (!userId) {\n      var r = { valid:'no', statusCode:401, response:{ success:false, error:'Invalid token.' } }; r;\n    } else {\n      var r = { valid:'yes', user_id:userId, email:email, current_password:currentPw, new_password:newPw }; r;\n    }\n  } catch(e) {\n    var r = { valid:'no', statusCode:401, response:{ success:false, error:'Invalid or expired token.' } }; r;\n  }\n}",
            "language": "javascript",
            "name": "Validate & Parse JWT",
            "saved": 0,
            "variable": "auth"
          }
        },
