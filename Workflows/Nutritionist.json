      "type": "app.CodeJS",
      "attrs": {
        "body": {
          "class": "",
          "opacity": "1",
          "stroke": "#4A4A51"
        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar title = String(m.title || '').trim();\nvar ingredients = String(m.ingredients || '').trim();\nvar servings = String(m.servings || '1');\n\nif (!title || !ingredients) {\n  var r = { valid:'no', statusCode:400, response:{ success:false, error:'title and ingredients are required.' } }; r;\n} else {\n  var prompt = 'Analyze the following recipe and provide detailed nutritional information per serving.\\n\\n';\n  prompt += 'Recipe: ' + title + '\\n';\n  prompt += 'Servings: ' + servings + '\\n';\n  prompt += 'Ingredients: ' + ingredients + '\\n\\n';\n  prompt += 'Please provide:\\n';\n  prompt += '1. Total calories per serving\\n';\n  prompt += '2. Macronutrients (protein, carbs, fat) in grams\\n';\n  prompt += '3. Key micronutrients\\n';\n  prompt += '4. Health notes (allergens, dietary info)\\n';\n  prompt += '5. A brief health rating (1-10)\\n\\n';\n  prompt += 'Format your response clearly with sections.';\n  var r = { valid:'yes', prompt:prompt }; r;\n}",
            "language": "javascript",
            "name": "Build Prompt",
            "saved": 0,
            "variable": "validated"
          }
        },
        "description": {
          "text": "var m = variables.mapper || {};\nvar title = String(m.title || '').trim();\nvar ingredients = String(m.ingredients || '').trim();\nvar servings = String(m.servings || '1');\n\nif (!title || !ingredients) {\n  var r = { valid:'no', statusCode:400, response:{ success:false, error:'title and ingredients are required.' } }; r;\n} else {\n  var prompt = 'Analyze the following recipe and provide detailed nutritional information per serving.\\n\\n';\n  prompt += 'Recipe: ' + title + '\\n';\n  prompt += 'Servings: ' + servings + '\\n';\n  prompt += 'Ingredients: ' + ingredients + '\\n\\n';\n  prompt += 'Please provide:\\n';\n  prompt += '1. Total calories per serving\\n';\n  prompt += '2. Macronutrients (protein, carbs, fat) in grams\\n';\n  prompt += '3. Key micronutrients\\n';\n  prompt += '4. Health notes (allergens, dietary info)\\n';\n  prompt += '5. A brief health rating (1-10)\\n\\n';\n  prompt += 'Format your response clearly with sections.';\n  var r = { valid:'yes', prompt:prompt }; r;\n}"
        },
