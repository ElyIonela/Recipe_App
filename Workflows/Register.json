        },
        "codeJs": {
          "extra": {
            "code": "var m = variables.mapper || {};\nvar name = String(m.name || '').trim();\nvar email = String(m.email || '').toLowerCase().trim();\nvar password = String(m.password || '');\n\nvar existingUser = variables.existing_user || {};\nvar rows = existingUser.rows || [];\n\nvar now = Date.now();\nvar nowISO = new Date(now).toISOString();\n\nif (rows.length > 0) {\n  var result = {\n    route: 'error',\n    statusCode: 409,\n    response: { success: false, error: 'An account with this email already exists.' }\n  };\n  result;\n} else {\n  // Hash the password with bcrypt\n  var hashed = bcryptHash(password, 10);\n  var secret = variables.secrets.my_jwt_secret;\n  if (!secret) {\n    var result = {\n      route: 'error',\n      statusCode: 500,\n      response: { success: false, error: 'Server configuration error.' }\n    };\n    result;\n  } else {\n    var result = {\n      route: 'register',\n      name: name,\n      email: email,\n      password_hash: hashed,\n      created_at: nowISO,\n      jwt_secret: secret,\n      iat: Math.floor(now / 1000),\n      exp: Math.floor(now / 1000) + 604800\n    };\n    result;\n  }\n}",
            "language": "javascript",
            "name": "Route Logic",
            "saved": 0,
            "variable": "router"
          }
        },
        "description": {
          "text": "var m = variables.mapper || {};\nvar name = String(m.name || '').trim();\nvar email = String(m.email || '').toLowerCase().trim();\nvar password = String(m.password || '');\n\nvar existingUser = variables.existing_user || {};\nvar rows = existingUser.rows || [];\n\nvar now = Date.now();\nvar nowISO = new Date(now).toISOString();\n\nif (rows.length > 0) {\n  var result = {\n    route: 'error',\n    statusCode: 409,\n    response: { success: false, error: 'An account with this email already exists.' }\n  };\n  result;\n} else {\n  // Hash the password with bcrypt\n  var hashed = bcryptHash(password, 10);\n  var secret = variables.secrets.my_jwt_secret;\n  if (!secret) {\n    var result = {\n      route: 'error',\n      statusCode: 500,\n      response: { success: false, error: 'Server configuration error.' }\n    };\n    result;\n  } else {\n    var result = {\n      route: 'register',\n      name: name,\n      email: email,\n      password_hash: hashed,\n      created_at: nowISO,\n      jwt_secret: secret,\n      iat: Math.floor(now / 1000),\n      exp: Math.floor(now / 1000) + 604800\n    };\n    result;\n  }\n}"
